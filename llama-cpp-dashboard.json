{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "prometheus", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus" },
      "description": "Speed of token generation (Predicted tokens)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 15 }
            ]
          },
          "unit": "tokensPerSecond"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "irate(llamacpp_completions_tokens_predicted_total[1m])",
          "legendFormat": "Generation Speed",
          "refId": "A"
        }
      ],
      "title": "Tokens per Second (Current)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "description": "KV Cache usage percentage",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "(llamacpp_kv_cache_tokens_used / llamacpp_kv_cache_tokens_total) * 100",
          "legendFormat": "KV Cache Fill",
          "refId": "A"
        }
      ],
      "title": "KV Cache Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "tokensPerSecond"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(llamacpp_completions_tokens_predicted_total[5m])",
          "legendFormat": "Generation Speed (5m avg)",
          "refId": "A"
        }
      ],
      "title": "Tokens per Second (over time)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(llamacpp_completions_prompt_seconds_total[5m])",
          "legendFormat": "Avg Prompt Eval Time",
          "refId": "A"
        }
      ],
      "title": "Prompt Evaluation Time (Rate)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["llm", "llama.cpp"],
  "timezone": "",
  "title": "llama.cpp Performance Dashboard (Official)",
  "uid": "llamacpp-official",
  "version": 1
}